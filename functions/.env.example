# Anthropic -- Claude email generation (generateDrafts, regenerateDraft)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini -- strategy, enrichment, outreach plans (getOutreachPlan, getStrategy)
GEMINI_API_KEY=...

# Resend -- email sending + inbound reply body fetch (sendApproved, processInboundEmail)
RESEND_API_KEY=re_...

# Note: For production, secrets are managed via Firebase:
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set RESEND_API_KEY
