# Firebase / Google Cloud
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: set if using a service account JSON instead of gcloud ADC
# GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Anthropic (Claude computer-use agent)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (email delivery)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=rob@asterleybros.com

# Instagram credentials (for DM automation)
INSTAGRAM_USERNAME=asterleybros
INSTAGRAM_PASSWORD=your-password

# Rotating proxy (for stealth scraping)
PROXY_HOST=your-proxy-host
PROXY_PORT=5000
PROXY_USERNAME=your-proxy-username
PROXY_PASSWORD=your-proxy-password
