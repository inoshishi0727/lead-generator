# Firebase / Google Cloud (used by Python scrapers via GitHub Actions)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: set if using a service account JSON instead of gcloud ADC
# GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json

# Google Gemini (scoring/enrichment in scrapers)
GEMINI_API_KEY=your-gemini-api-key

# Anthropic (used by Cloud Functions, not scrapers -- see functions/.env.example)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (used by Cloud Functions -- see functions/.env.example)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=rob@asterleybros.com
