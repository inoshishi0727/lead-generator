# Firebase / Google Cloud
FIREBASE_PROJECT_ID=your-firebase-project-id
# Service account JSON for Firestore access (required for scraper/enrichment)
GOOGLE_APPLICATION_CREDENTIALS=path/to/gcloud-creds.json

# Google Gemini (enrichment + scoring)
GEMINI_API_KEY=your-gemini-api-key

# Anthropic (used by Cloud Functions -- see functions/.env.example)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend (used by Cloud Functions -- see functions/.env.example)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=rob@asterleybros.com

# Residential proxy (optional, for scraping without blocks)
# PROXY_HOST=go.resiprox.com
# PROXY_PORT=5000
# PROXY_USERNAME=your-proxy-username
# PROXY_PASSWORD=your-proxy-password
